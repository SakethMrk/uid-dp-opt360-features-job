    </dependency>
    <dependency>
      <groupId>org.apache.iceberg</groupId>
      <artifactId>iceberg-api</artifactId>
      <version>1.4.3</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <artifactId>iceberg-bundled-guava</artifactId>
          <groupId>org.apache.iceberg</groupId>
