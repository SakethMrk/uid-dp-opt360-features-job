    </dependency>
    <dependency>
      <groupId>org.apache.flink</groupId>
      <artifactId>flink-java</artifactId>
      <version>1.17.2</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <artifactId>chill-java</artifactId>
