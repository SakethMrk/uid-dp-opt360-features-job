      <artifactId>flink-table-common</artifactId>
      <version>1.17.2</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <artifactId>icu4j</artifactId>
          <groupId>com.ibm.icu</groupId>
        </exclusion>
